    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_rainbow"
    android:orientation="vertical"
    android:padding="7dp">

    <!-- Header: status tag + status/streak (tap = toggle theme) + updated -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_medium_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_medium_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="4dp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="Idle · 0d streak"
            android:textColor="#FFFFFFCC"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/widget_medium_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Updated: never"
            android:textColor="#FFFFFFDD"
            android:textSize="7sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- GPS coordinates + accuracy -->
    <TextView
        android:id="@+id/widget_medium_gps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="GPS: no fix yet"
        android:textColor="#FFFFFF99"
        android:textSize="6sp" />

