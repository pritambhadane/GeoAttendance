<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_medium_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_rainbow"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Header: status tag + status/streak (tap = toggle theme) + updated -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_medium_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_medium_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="5dp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="Idle · 0d streak"
            android:textColor="#FFFFFFCC"
            android:textSize="8sp" />

        <TextView
            android:id="@+id/widget_medium_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Updated: never"
            android:textColor="#FFFFFFDD"
            android:textSize="8sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- GPS coordinates + accuracy -->
    <TextView
        android:id="@+id/widget_medium_gps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="GPS: no fix yet"
        android:textColor="#FFFFFF99"
        android:textSize="7sp" />

    <!-- Per-profile groups: last 3 days each -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widget_medium_p1_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="0dp"
            android:layout_marginRight="3dp"
            android:background="@drawable/widget_card"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_medium_p1_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="Profile 1"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_medium_p1_d1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />

            <TextView
                android:id="@+id/widget_medium_p1_d2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />

            <TextView
                android:id="@+id/widget_medium_p1_d3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_medium_p2_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="3dp"
            android:layout_marginRight="3dp"
            android:background="@drawable/widget_card"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_medium_p2_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="Profile 2"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_medium_p2_d1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />

            <TextView
                android:id="@+id/widget_medium_p2_d2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />

            <TextView
                android:id="@+id/widget_medium_p2_d3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_medium_p3_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="3dp"
            android:layout_marginRight="3dp"
            android:background="@drawable/widget_card"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_medium_p3_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="Profile 3"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_medium_p3_d1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />

            <TextView
                android:id="@+id/widget_medium_p3_d2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />

            <TextView
                android:id="@+id/widget_medium_p3_d3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_medium_p4_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="3dp"
            android:layout_marginRight="0dp"
            android:background="@drawable/widget_card"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_medium_p4_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="Profile 4"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_medium_p4_d1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />

            <TextView
                android:id="@+id/widget_medium_p4_d2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />

            <TextView
                android:id="@+id/widget_medium_p4_d3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text=""
                android:textColor="#FFFFFFDD"
                android:textSize="7sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
