<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E293B"
    android:padding="12dp">

    <!-- ── Header: last location scanned ──────────────────────────────── -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F172A"
        android:padding="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Last Location Scanned"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/widget_location_coords"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="#F1F5F9"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_location_accuracy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#38BDF8"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_location_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last 4 Days"
        android:textColor="#94A3B8"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp" />

    <!-- ── List: last 4 days of attendance logs ───────────────────────── -->
    <ListView
        android:id="@+id/widget_log_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#334155"
        android:dividerHeight="1px" />

    <TextView
        android:id="@+id/widget_empty_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No attendance logs yet"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="16dp" />

</LinearLayout>
