<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E6101827"
    android:padding="12dp">

    <!-- Header: last GPS fix -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#2038BDF8"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="6dp">

            <TextView
                android:id="@+id/widget_location_coords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No location yet"
                android:textColor="#F1F5F9"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_location_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_location_accuracy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#38BDF8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#2038BDF8"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />
    </LinearLayout>

    <!-- Section label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="5dp">

        <View
            android:layout_width="3dp"
            android:layout_height="12dp"
            android:background="#38BDF8"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LAST 4 DAYS"
            android:textColor="#38BDF8"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <TextView
            android:id="@+id/widget_updated_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#475569"
            android:textSize="9sp" />
    </LinearLayout>

    <!--
        Row container: rows are added dynamically via RemoteViews.addView()
        after removeAllViews() — compatible with minSdk 14+.
    -->
    <LinearLayout
        android:id="@+id/widget_rows_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/widget_empty_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No attendance logs yet.\nOpen GeoAttendance to get started."
        android:textColor="#475569"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
