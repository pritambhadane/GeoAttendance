<?xml version="1.0" encoding="utf-8"?>
<!--
    Single attendance log row for the home-screen widget.
    Populated via RemoteViews.setTextViewText / setViewVisibility directly
    from AttendanceWidgetProvider — no RemoteViewsFactory needed.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#1AFFFFFF"
    android:minHeight="48dp">

    <!-- Colored left accent bar (green=present, amber=incomplete, red=absent) -->
    <View
        android:id="@+id/row_accent"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="#4ADE80" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- Top row: profile name + date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/row_profile_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Profile"
                android:textColor="#F1F5F9"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/row_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mon, 01 Jan"
                android:textColor="#94A3B8"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Bottom row: check-in | check-out | duration | status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp">

            <TextView
                android:id="@+id/row_checkin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="In: —"
                android:textColor="#94A3B8"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/row_checkout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Out: —"
                android:textColor="#94A3B8"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/row_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#CBD5E1"
                android:textSize="10sp"
                android:layout_marginEnd="6dp" />

            <!-- Status badge -->
            <TextView
                android:id="@+id/row_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#4ADE80"
                android:background="#224ADE80"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
